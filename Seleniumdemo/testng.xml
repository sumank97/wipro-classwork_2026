<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="ParallelGridSuite"
       parallel="tests"
       thread-count="2">

    <!-- Chrome Browser Test -->

    <test name="ChromeTest">

        <parameter name="browser"
                   value="chrome"/>

        <classes>

            <class name="demo.ParallelGridDemo"/>

        </classes>

    </test>

    <!-- Edge Browser Test -->

    <test name="EdgeTest">

        <parameter name="browser"
                   value="edge"/>

        <classes>

            <class name="demo.ParallelGridDemo"/>

        </classes>

    </test>

</suite>